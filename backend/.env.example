# ============================================
# SAVVY UK — BACKEND ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database — Neon PostgreSQL (free tier)
# Sign up: https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/savvyuk?sslmode=require"

# Redis — Upstash (free tier)
# Sign up: https://upstash.com
REDIS_URL="redis://default:password@eu1-xxx.upstash.io:6379"

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-also-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# AI PROVIDER
# AI_PROVIDER=gemini  → Google Gemini Flash (defaults to gemini-2.0-flash)
#   Free limits: 15 req/min, 1 million tokens/day
#   Get key: https://aistudio.google.com/app/apikey
#
# AI_PROVIDER=claude  → Anthropic Claude Sonnet (paid, best quality)
#   Prompt caching enabled — saves up to 90% on repeated system prompts
#   Get key: https://console.anthropic.com
# ─────────────────────────────────────────────
AI_PROVIDER=gemini

# Google Gemini (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=AIza_your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Google OAuth
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type)
# Add Authorized redirect URI: http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email — Resend (free: 3,000 emails/month)
# Sign up: https://resend.com
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@savvy-uk.com

# ─────────────────────────────────────────────
# PAYMENTS
# Stripe is recommended for UK. Dodo is an alternative.
# ─────────────────────────────────────────────

# Stripe (recommended — standard for UK payments)
# Sign up: https://stripe.com
# 1. Create Products in Stripe Dashboard (Products → Add product)
# 2. Create monthly recurring prices → copy the price_xxx IDs below
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx_pro_monthly
STRIPE_PREMIUM_PRICE_ID=price_xxx_premium_monthly

# Dodo Payments (alternative — India-based Merchant of Record)
# Sign up: https://dodopayments.com
DODO_API_KEY=sk_live_xxx
DODO_WEBHOOK_SECRET=whsec_xxx

# Plan display prices (in pence — used for Dodo / UI display)
PLAN_FREE_PRICE=0
PLAN_PRO_PRICE=499
PLAN_PREMIUM_PRICE=999

# Affiliate Partners (all optional)
ENERGY_SHOP_AFFILIATE_ID=your_affiliate_id
UKPOWER_AFFILIATE_ID=your_affiliate_id
USWITCH_AFFILIATE_ID=your_affiliate_id
SWITCHITY_AFFILIATE_ID=your_affiliate_id
GOCOMPARE_AFFILIATE_ID=your_affiliate_id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# ============================================
# SAVVY UK — BACKEND ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database — Neon PostgreSQL
# Get from: https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.eu-west-2.aws.neon.tech/savvyuk?sslmode=require"

# Redis — Upstash (free tier works great)
# Get from: https://upstash.com
REDIS_URL="redis://default:password@eu1-xxx.upstash.io:6379"

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic — Claude AI
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# Email — Resend (free 3000/month)
# Get from: https://resend.com
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@savvy-uk.com

# Dodo Payments — Merchant of Record (India → UK)
# Get from: https://dodopayments.com
DODO_API_KEY=sk_live_xxx
DODO_WEBHOOK_SECRET=whsec_xxx

# Plans pricing (in pence)
PLAN_FREE_PRICE=0
PLAN_PRO_PRICE=499
PLAN_PREMIUM_PRICE=999

# Affiliate Partners
# The Energy Shop affiliate
ENERGY_SHOP_AFFILIATE_ID=your_affiliate_id

# UKPower affiliate
UKPOWER_AFFILIATE_ID=your_affiliate_id

# Uswitch broadband affiliate
USWITCH_AFFILIATE_ID=your_affiliate_id

# Switchity broadband affiliate
SWITCHITY_AFFILIATE_ID=your_affiliate_id

# GoCompare insurance affiliate
GOCOMPARE_AFFILIATE_ID=your_affiliate_id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Google OAuth
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type)
# Add Authorized redirect URIs: http://localhost:3000/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

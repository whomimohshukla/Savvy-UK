# ============================================
# SAVVY UK — FRONTEND ENVIRONMENT VARIABLES
# Copy this to .env.local
# ============================================

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# App
NEXT_PUBLIC_APP_NAME=Savvy UK
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — must match GOOGLE_CLIENT_ID in backend/.env
# Get from: https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Stripe publishable key (safe to expose — starts with pk_)
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Dodo Payments public key (alternative to Stripe)
NEXT_PUBLIC_DODO_PUBLIC_KEY=pk_live_xxx
